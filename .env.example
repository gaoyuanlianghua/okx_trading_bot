# 阿里云OSS配置
# 请将这些配置添加到系统的环境变量中，或复制到 .env 文件

# OSS AccessKey ID
OSS_ACCESS_KEY_ID=your_access_key_id_here

# OSS AccessKey Secret
OSS_ACCESS_KEY_SECRET=your_access_key_secret_here

# OSS 内网域名（使用内网域名可以避免流量费用）
OSS_ENDPOINT=oself-jh.oss-cn-hangzhou-internal.aliyuncs.com

# OSS 存储桶名称
OSS_BUCKET_NAME=oself-jh

# 是否启用OSS备份 (true/false)
ENABLE_OSS_BACKUP=true
